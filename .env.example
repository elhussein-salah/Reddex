# ──────────────────────────────────────────────────────
# Reddex — Environment Variables
# Copy this file to .env and fill in the real values.
# ──────────────────────────────────────────────────────

# Database (Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=reddexdb
PORT=3000
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5433/reddexdb?schema=public

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=CHANGE_ME

# CORS (comma-separated origins, or * for development)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP (Brevo)
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=your_smtp_user
MAIL_PASS=your_smtp_key
MAIL_FROM="Reddex Support <no-reply@reddex.com>"

# Seeded bootstrap super admin (used by prisma seed)
SEED_SUPER_ADMIN_NAME=Super Admin
SEED_SUPER_ADMIN_EMAIL=superadmin@reddex.com
SEED_SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SEED_SUPER_ADMIN_PHONE=+12025550199
