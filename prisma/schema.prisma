// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOCTOR
  PATIENT
  ADMIN
}

enum FollowUpStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model users {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  photourl  String?
  name      String
  phone     String    @unique
  role      Role
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  patients  patients?
  doctors   doctors?
}

model patients {
  id           Int         @id @default(autoincrement())
  birthdate    DateTime
  SSN          String      @unique
  healthStatus String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  userId       Int         @unique
  user         users       @relation(fields: [userId], references: [id])
  labReports   LabReport[]
  followUps    FollowUp[]
}

model LabReport {
  id         Int     @id @default(autoincrement())
  patient_id Int
  photo      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient patients    @relation(fields: [patient_id], references: [id])
  results LabResult[]
}

model LabResult {
  id        Int     @id @default(autoincrement())
  report_id Int
  // resultsJson Json?
  name      String // Hb, RBC, etc
  value     Float
  unit      String? // g/dL, %, etc

  report LabReport @relation(fields: [report_id], references: [id])
}

model doctors {
  id                     Int        @id @default(autoincrement())
  specialty              String
  SSN                    String     @unique
  licenseMedicalNumber   String     @unique
  licenseMedicalPhotoUrl String
  yearsExperience        Int
  idCardPhotoUrl         String
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  userId                 Int        @unique
  user                   users      @relation(fields: [userId], references: [id])
  followUps              FollowUp[]
}

model FollowUp {
  id        Int    @id @default(autoincrement())
  doctorId  Int
  patientId Int
  notes     String

  status FollowUpStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor  doctors  @relation(fields: [doctorId], references: [id])
  patient patients @relation(fields: [patientId], references: [id])

  @@index([doctorId, patientId])
}

model PasswordResetOtp {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
}
