// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOCTOR
  PATIENT
  ADMIN
  SUPER_ADMIN
}

enum FollowUpStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
}

model users {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  password     String
  photourl     String?
  name         String
  gender       Gender
  phone        String        @unique
  SSN          String        @unique
  birthdate    DateTime      @db.Date
  role         Role
  isActive     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  patients     patients?
  doctors      doctors?
  deviceTokens DeviceToken[]
}

model patients {
  id           Int      @id @default(autoincrement())
  healthStatus String
  diseases     String[]
  treatments   String[]
  bloodType    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId Int   @unique
  user   users @relation(fields: [userId], references: [id], onDelete: Cascade)

  followUps     FollowUp[]
  prescriptions Prescription[]
  results       Result[]
}

model doctors {
  id                     Int            @id @default(autoincrement())
  specialty              String
  licenseMedicalNumber   String         @unique
  licenseMedicalPhotoUrl String
  yearsExperience        Int
  idCardPhotoUrl         String
  nameOfClinic           String?
  locationOfClinic       String?
  photoOfClinicUrl       String?
  workingHours           String?
  workdays               String[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  userId                 Int            @unique
  user                   users          @relation(fields: [userId], references: [id], onDelete: Cascade)
  followUps              FollowUp[]
  prescriptions          Prescription[]
}

model labs {
  id         Int      @id @default(autoincrement())
  name       String
  imageUrl   String?
  workhours  String?
  workdays   String[]
  phone      String?
  location   String?
  websiteUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FollowUp {
  id        Int @id @default(autoincrement())
  doctorId  Int
  patientId Int

  status  FollowUpStatus @default(PENDING)
  endDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor        doctors        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       patients       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  @@index([doctorId, patientId])
  @@index([patientId, status])
  @@index([doctorId, status])
}

model Prescription {
  id             Int      @id @default(autoincrement())
  followUpId     Int
  doctorId       Int
  patientId      Int
  medicationName String
  instructions   String?
  durationInDays Int
  startDate      DateTime @db.Date
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  followUp FollowUp           @relation(fields: [followUpId], references: [id], onDelete: Cascade)
  doctor   doctors            @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient  patients           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doses    PrescriptionDose[]

  @@index([doctorId, patientId])
  @@index([patientId, startDate])
}

model PrescriptionDose {
  id             Int      @id @default(autoincrement())
  prescriptionId Int
  exactTime      DateTime
  status         String   @default("PENDING") // PENDING, SENT, CANCELLED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([exactTime, status])
}

model DeviceToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  deviceOs  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetOtp {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([email, expiresAt])
}

model Result {
  id        Int      @id @default(autoincrement())
  patientId Int
  result    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient patients @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}
