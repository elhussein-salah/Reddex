// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DOCTOR
  PATIENT
  ADMIN
  SUPER_ADMIN
}

enum FollowUpStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum FollowUpLifecycleStatus {
  ACTIVE
  ENDED
}

enum PrescriptionStatus {
  ISSUED
  FILLED
  EXPIRED
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
}

model users {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  photourl  String?
  name      String
  gender    Gender
  phone     String    @unique
  SSN       String    @unique
  birthdate DateTime  @db.Date
  role      Role
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  patients  patients?
  doctors   doctors?
}

model patients {
  id           Int      @id @default(autoincrement())
  healthStatus String
  diseases     String[]
  treatments   String[]
  bloodType    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId Int   @unique
  user   users @relation(fields: [userId], references: [id], onDelete: Cascade)

  followUps     FollowUp[]
  prescriptions Prescription[]
}

model doctors {
  id                     Int            @id @default(autoincrement())
  specialty              String
  licenseMedicalNumber   String         @unique
  licenseMedicalPhotoUrl String
  yearsExperience        Int
  idCardPhotoUrl         String
  nameOfClinic           String?
  locationOfClinic       String?
  photoOfClinicUrl       String?
  workingHours           String?
  workdays               String[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  userId                 Int            @unique
  user                   users          @relation(fields: [userId], references: [id], onDelete: Cascade)
  followUps              FollowUp[]
  prescriptions          Prescription[]
}

model labs {
  id         Int      @id @default(autoincrement())
  name       String
  imageUrl   String?
  workhours  String?
  workdays   String[]
  phone      String?
  location   String?
  websiteUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FollowUp {
  id        Int    @id @default(autoincrement())
  doctorId  Int
  patientId Int
  notes     String

  status          FollowUpStatus          @default(PENDING)
  lifecycleStatus FollowUpLifecycleStatus @default(ENDED)
  endDate         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor        doctors        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       patients       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  @@index([doctorId, patientId])
  @@index([patientId, status])
  @@index([doctorId, status])
}

model Prescription {
  id             Int                @id @default(autoincrement())
  followUpId     Int
  doctorId       Int
  patientId      Int
  medicationName String
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  status         PrescriptionStatus @default(ISSUED)
  issuedAt       DateTime           @default(now())
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  followUp FollowUp @relation(fields: [followUpId], references: [id], onDelete: Cascade)
  doctor   doctors  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient  patients @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId, patientId])
  @@index([followUpId, status])
  @@index([patientId, issuedAt])
}

model PasswordResetOtp {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([email, expiresAt])
}
